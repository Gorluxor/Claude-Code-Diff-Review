#!/usr/bin/env python3
"""
claude-diff — CLI companion for claude-diff-review.

Commands:
  status            Show current session state and tracked files
  accept            Accept all changes and clean up shadow copies
  diff [path]       Open VS Code diff for one or all tracked files
  log               Show full event log for the current session
  config            Show or edit configuration (--wizard to re-run setup)
  install           Install hooks into Claude Code settings
  uninstall         Remove hooks from Claude Code settings
  migrate           Sync hooks/lib from newest cache version to all older ones
  pause             Pause diff tracking (hooks do nothing until resumed)
  resume            Resume diff tracking
"""

import sys
import os
import json
import argparse
import subprocess
import shutil
import difflib
from pathlib import Path

# Resolve the installation directory
INSTALL_DIR = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(INSTALL_DIR))

from lib.state import (
    load_state,
    save_state,
    get_edited_files,
    get_shadow_path,
    get_working_dir,
    get_session_dir,
    get_log_file,
    cleanup_session,
)


# ──────────────────────────────────────────────────────────────────────
# ANSI
# ──────────────────────────────────────────────────────────────────────

RESET = "\033[0m"
BOLD = "\033[1m"
DIM = "\033[2m"
RED = "\033[31m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
BLUE = "\033[34m"
MAGENTA = "\033[35m"
CYAN = "\033[36m"


# ──────────────────────────────────────────────────────────────────────
# Helpers
# ──────────────────────────────────────────────────────────────────────

def format_path(abs_path: str) -> str:
    wd = get_working_dir()
    try:
        return str(Path(abs_path).relative_to(wd))
    except ValueError:
        return abs_path


def get_config_path() -> Path:
    return Path.home() / ".claude-diff-review" / "config.json"


def load_config() -> dict:
    cp = get_config_path()
    if cp.exists():
        try:
            return json.loads(cp.read_text())
        except Exception:
            pass
    return {
        "review_mode":          "interactive",
        "interactive_provider": "claude-code",
        "review_scope":         "session",
        "auto_cleanup":         True,
    }


def save_config(config: dict):
    cp = get_config_path()
    cp.parent.mkdir(parents=True, exist_ok=True)
    cp.write_text(json.dumps(config, indent=2))


# ──────────────────────────────────────────────────────────────────────
# Commands
# ──────────────────────────────────────────────────────────────────────

def cmd_status(args):
    """Show current session state."""
    state = load_state()
    edited = get_edited_files()

    if not edited:
        print(f"{DIM}No files tracked in current session.{RESET}")
        return

    print(f"\n{BOLD}{MAGENTA}◆ claude-diff-review — session status{RESET}\n")

    total_add = 0
    total_del = 0
    decisions = state.get("decisions", {})

    for abs_path, count in sorted(edited.items()):
        rel = format_path(abs_path)
        shadow = get_shadow_path(abs_path)
        real = Path(abs_path)

        try:
            old = shadow.read_text(errors="replace").splitlines() if shadow.exists() else []
            new = real.read_text(errors="replace").splitlines() if real.exists() else []
            diff = list(difflib.unified_diff(old, new))
            adds = sum(1 for l in diff if l.startswith("+") and not l.startswith("+++"))
            dels = sum(1 for l in diff if l.startswith("-") and not l.startswith("---"))
        except Exception:
            adds, dels = 0, 0

        total_add += adds
        total_del += dels

        add_str = f"{GREEN}+{adds}{RESET}" if adds else f"{DIM}+0{RESET}"
        del_str = f"{RED}-{dels}{RESET}" if dels else f"{DIM}-0{RESET}"
        edits_str = f"{DIM}({count} edit{'s' if count != 1 else ''}){RESET}"
        decision = decisions.get(abs_path, "")
        dec_str = f"  {DIM}[{decision}]{RESET}" if decision else ""
        print(f"  {BOLD}{rel}{RESET}  {add_str} {del_str}  {edits_str}{dec_str}")

    round_num = state.get("review_round", 0)
    round_str = f"  round {round_num}" if round_num > 0 else ""
    print(f"\n  {DIM}Total: {GREEN}+{total_add}{RESET} {RED}-{total_del}{RESET} "
          f"across {len(edited)} file{'s' if len(edited) != 1 else ''}{round_str}{RESET}\n")


def cmd_accept(args):
    """Accept all changes and clean up shadow copies."""
    edited = get_edited_files()

    if not edited:
        print(f"{DIM}Nothing to accept — no tracked edits.{RESET}")
        return

    count = len(edited)
    print(f"{GREEN}✓{RESET} Accepted {count} file{'s' if count != 1 else ''}.")

    config = load_config()
    if config.get("auto_cleanup", True):
        cleanup_session()
        print(f"{DIM}  Shadow copies cleaned up.{RESET}")
    else:
        state = load_state()
        state["edited_files"] = {}
        state["decisions"] = {}
        save_state(state)
        print(f"{DIM}  Shadow copies retained (auto_cleanup=false).{RESET}")


def cmd_diff(args):
    """Open diffs in VS Code or terminal."""
    edited = get_edited_files()
    if not edited:
        print(f"{DIM}No tracked edits to diff.{RESET}")
        return

    config = load_config()
    mode = args.mode or config.get("review_mode", "vscode")

    targets = edited
    if args.path:
        abs_path = str(Path(args.path).resolve())
        match = None
        for p in edited:
            if p == abs_path or format_path(p) == args.path:
                match = p
                break
        if not match:
            print(f"{RED}✗{RESET} File not tracked: {args.path}")
            return
        targets = {match: edited[match]}

    for abs_path in sorted(targets):
        rel = format_path(abs_path)
        shadow = get_shadow_path(abs_path)
        real = Path(abs_path)

        if mode in ("vscode", "interactive"):
            try:
                subprocess.Popen(
                    ["code", "--diff", str(shadow), str(real)],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                )
                print(f"  {CYAN}▶{RESET} Opened diff: {rel}")
            except FileNotFoundError:
                print(f"  {YELLOW}⚠{RESET} VS Code CLI not found, printing to terminal:")
                _print_file_diff(shadow, real, rel)
        else:
            _print_file_diff(shadow, real, rel)


def _print_file_diff(shadow: Path, real: Path, rel: str):
    try:
        old = shadow.read_text(errors="replace").splitlines() if shadow.exists() else []
        new = real.read_text(errors="replace").splitlines() if real.exists() else []
    except Exception:
        old, new = [], []

    diff = list(difflib.unified_diff(
        old, new,
        fromfile=f"a/{rel}",
        tofile=f"b/{rel}",
        lineterm=""
    ))
    if not diff:
        print(f"  {DIM}(no changes) {rel}{RESET}")
        return

    for line in diff:
        if line.startswith("+++") or line.startswith("---"):
            print(f"  {BOLD}{line}{RESET}")
        elif line.startswith("@@"):
            print(f"  {CYAN}{line}{RESET}")
        elif line.startswith("+"):
            print(f"  {GREEN}{line}{RESET}")
        elif line.startswith("-"):
            print(f"  {RED}{line}{RESET}")
        else:
            print(f"  {line}")
    print()


def cmd_config(args):
    """Show or modify configuration."""
    config = load_config()

    if args.wizard:
        _run_config_wizard(config)
        return

    if args.key and args.value:
        config[args.key] = args.value
        save_config(config)
        print(f"{GREEN}✓{RESET} Set {args.key} = {args.value}")
    elif args.key:
        val = config.get(args.key, f"{RED}(not set){RESET}")
        print(f"  {args.key} = {val}")
    else:
        print(f"\n{BOLD}Configuration{RESET} ({get_config_path()})\n")
        for k, v in config.items():
            print(f"  {k} = {BOLD}{v}{RESET}")
        print()
        print(f"{DIM}  review_mode:  interactive | vscode | terminal | summary{RESET}")
        print(f"{DIM}    interactive — VS Code MCP openDiff, per-hunk accept/reject, re-engages Claude{RESET}")
        print(f"{DIM}    vscode      — code --diff, blocks per file, detects accept/reject/modified{RESET}")
        print(f"{DIM}  interactive_provider: claude-code | copilot{RESET}")
        print(f"{DIM}    claude-code  — Claude Code MCP openDiff (blocking, one file at a time){RESET}")
        print(f"{DIM}    copilot      — stage in git + Copilot 'Review Changes' panel (non-blocking){RESET}")
        print(f"{DIM}  review_scope: session (all diffs at Stop) | "
              f"file (progressive, per-file as Claude works){RESET}")
        print(f"{DIM}  vscode_wait:  true (block per file, detect decisions) | false (fire-and-forget){RESET}")
        print(f"{DIM}  auto_cleanup: true | false{RESET}")
        print(f"\n  {DIM}Use --wizard to re-run the interactive setup.{RESET}\n")


def _run_config_wizard(current_config: dict):
    """Re-run the setup wizard from session_start."""
    hooks_dir = INSTALL_DIR / "hooks"
    sys.path.insert(0, str(hooks_dir))
    from session_start import _run_setup_wizard, CONFIG_PATH  # noqa: PLC0415

    if CONFIG_PATH.exists():
        print(f"{DIM}Current config ({CONFIG_PATH}):{RESET}")
        for k, v in current_config.items():
            print(f"  {BOLD}{k}{RESET}: {v}")
        print()

    old_text = CONFIG_PATH.read_text() if CONFIG_PATH.exists() else None
    CONFIG_PATH.unlink(missing_ok=True)
    _run_setup_wizard()

    if CONFIG_PATH.exists():
        print(f"{GREEN}✓{RESET}  Config updated.")
    else:
        if old_text is not None:
            CONFIG_PATH.write_text(old_text)
            print(f"{YELLOW}⚠{RESET}  No terminal available — previous config restored.")
        else:
            from session_start import _DEFAULTS  # noqa: PLC0415
            CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
            CONFIG_PATH.write_text(json.dumps(_DEFAULTS, indent=2))
            print(f"{YELLOW}⚠{RESET}  No terminal available — defaults written.")


def cmd_log(args):
    """Show the session event log."""
    log_file = get_log_file()
    if not log_file.exists():
        print(f"{DIM}No events logged yet for this session.{RESET}")
        return

    # Color map per hook
    hook_colors = {
        "session_start": CYAN,
        "pre_tool_use":  GREEN,
        "post_tool_use": GREEN,
        "stop":          MAGENTA,
        "review":        YELLOW,
        "ide":           BLUE,
    }

    lines = log_file.read_text().splitlines()
    if args.lines:
        lines = lines[-args.lines:]

    if not lines:
        print(f"{DIM}Log is empty.{RESET}")
        return

    print(f"\n{BOLD}{MAGENTA}◆ claude-diff-review — event log{RESET}")
    print(f"{DIM}  {log_file}{RESET}\n")

    for line in lines:
        # Format: "2026-04-12 13:37:51  [hook]  message  key=val"
        parts = line.split("  ", 3)
        if len(parts) < 3:
            print(f"  {DIM}{line}{RESET}")
            continue
        ts, hook_raw, rest = parts[0], parts[1], "  ".join(parts[2:])
        hook_name = hook_raw.strip("[]")
        color = hook_colors.get(hook_name, DIM)
        print(f"  {DIM}{ts}{RESET}  {color}{hook_raw}{RESET}  {rest}")

    print()

    if args.follow:
        import time as _time
        print(f"{DIM}  (following — Ctrl+C to stop){RESET}\n")
        try:
            with open(log_file) as fh:
                fh.seek(0, 2)  # seek to end
                while True:
                    line = fh.readline()
                    if line:
                        parts = line.rstrip().split("  ", 3)
                        if len(parts) >= 3:
                            ts, hook_raw, rest = parts[0], parts[1], "  ".join(parts[2:])
                            hook_name = hook_raw.strip("[]")
                            color = hook_colors.get(hook_name, DIM)
                            print(f"  {DIM}{ts}{RESET}  {color}{hook_raw}{RESET}  {rest}")
                        else:
                            print(f"  {DIM}{line.rstrip()}{RESET}")
                    else:
                        _time.sleep(0.3)
        except KeyboardInterrupt:
            pass


def cmd_migrate(args):
    """
    Copy hooks/ and lib/ from the newest installed cache version to all
    older cache versions so they all run the same code.

    The plugin manager may keep multiple version directories cached;
    Claude Code picks one at runtime. Running this after an upgrade
    ensures every cached copy is in sync without needing a full reinstall.
    """
    cache_root = Path.home() / ".claude" / "plugins" / "cache" / "claude-diff-review" / "claude-diff-review"
    if not cache_root.exists():
        print(f"{YELLOW}⚠{RESET}  Plugin cache not found at {cache_root}")
        print(f"  {DIM}Nothing to migrate.{RESET}")
        return

    versions = sorted(
        [d for d in cache_root.iterdir() if d.is_dir()],
        key=lambda d: [int(x) for x in d.name.split(".") if x.isdigit()],
    )

    if len(versions) < 2:
        print(f"{DIM}Only one cached version found — nothing to migrate.{RESET}")
        return

    newest = versions[-1]
    older  = versions[:-1]

    print(f"\n{BOLD}{MAGENTA}◆ claude-diff-review — cache migration{RESET}\n")
    print(f"  {DIM}Newest: {newest.name}{RESET}")
    print(f"  {DIM}Syncing to: {', '.join(v.name for v in older)}{RESET}\n")

    sync_dirs = ["hooks", "lib"]
    copied = 0
    errors = 0

    for old_ver in older:
        for d in sync_dirs:
            src_dir = newest / d
            dst_dir = old_ver / d
            if not src_dir.exists():
                continue
            dst_dir.mkdir(parents=True, exist_ok=True)
            for src_file in src_dir.iterdir():
                if src_file.suffix == ".py":
                    dst_file = dst_dir / src_file.name
                    try:
                        shutil.copy2(str(src_file), str(dst_file))
                        copied += 1
                    except Exception as e:
                        print(f"  {RED}✗{RESET}  {old_ver.name}/{d}/{src_file.name}: {e}")
                        errors += 1

        print(f"  {GREEN}✓{RESET}  {old_ver.name} — synced")

    print(f"\n  {DIM}{copied} file{'s' if copied != 1 else ''} copied"
          f"{f', {errors} error(s)' if errors else ''}.{RESET}")
    print(f"\n  {DIM}Run /reload-plugins in Claude Code to pick up the changes.{RESET}\n")


def cmd_pause(args):
    """Globally pause diff tracking — hooks fire but do nothing."""
    config = load_config()
    config["paused"] = True
    save_config(config)
    print(f"{YELLOW}⏸{RESET}  claude-diff-review paused. Edits will not be tracked.")
    print(f"  Run {BOLD}claude-diff resume{RESET} to re-enable.")


def cmd_resume(args):
    """Resume diff tracking after a pause."""
    config = load_config()
    config.pop("paused", None)
    save_config(config)
    print(f"{GREEN}▶{RESET}  claude-diff-review active. Edits will be tracked.")


def cmd_install(args):
    """Install hooks into Claude Code settings."""
    settings_path = args.settings or Path.home() / ".claude" / "settings.json"
    settings_path = Path(settings_path)

    settings = {}
    if settings_path.exists():
        try:
            settings = json.loads(settings_path.read_text())
        except json.JSONDecodeError:
            print(f"{YELLOW}⚠{RESET} Existing settings.json is malformed. Creating backup...")
            backup = settings_path.with_suffix(".json.backup")
            shutil.copy2(str(settings_path), str(backup))
            print(f"  Backup: {backup}")

    hooks = settings.setdefault("hooks", {})

    hook_dir = INSTALL_DIR / "hooks"
    our_hooks = {
        "SessionStart": [{
            "hooks": [{
                "type": "command",
                "command": f"python3 {hook_dir / 'session_start.py'}",
                "timeout": 5,
            }]
        }],
        "PreToolUse": [{
            "matcher": "Edit|Write|MultiEdit",
            "hooks": [{
                "type": "command",
                "command": f"python3 {hook_dir / 'pre_tool_use.py'}",
                "timeout": 5,
            }]
        }],
        "PostToolUse": [{
            "matcher": "Edit|Write|MultiEdit",
            "hooks": [{
                "type": "command",
                "command": f"python3 {hook_dir / 'post_tool_use.py'}",
                "timeout": 5,
            }]
        }],
        "Stop": [{
            "hooks": [{
                "type": "command",
                "command": f"python3 {hook_dir / 'stop.py'}",
                "timeout": 600,
            }]
        }],
    }

    for event, matchers in our_hooks.items():
        existing = hooks.get(event, [])
        existing = [
            m for m in existing
            if not any("claude-diff-review" in str(h.get("command", ""))
                      or "diff_review" in str(h.get("command", ""))
                      for h in m.get("hooks", []))
        ]
        existing.extend(matchers)
        hooks[event] = existing

    settings["hooks"] = hooks

    permissions = settings.setdefault("permissions", {})
    allow = permissions.setdefault("allow", [])
    for tool in ["Edit", "Write", "MultiEdit"]:
        if tool not in allow:
            allow.append(tool)
    permissions["allow"] = allow

    settings_path.parent.mkdir(parents=True, exist_ok=True)
    settings_path.write_text(json.dumps(settings, indent=2))

    print(f"""
{GREEN}✓{RESET} {BOLD}claude-diff-review installed!{RESET}

  Settings:  {settings_path}
  Hooks dir: {hook_dir}

{BOLD}What happens now:{RESET}
  1. File edits are auto-approved (no permission prompts)
  2. Originals are captured to a shadow directory
  3. When Claude finishes, you review diffs interactively
  4. Use {BOLD}claude-diff accept{RESET} to finalize

{DIM}Restart Claude Code for hooks to take effect.{RESET}
""")


def cmd_uninstall(args):
    """Remove hooks from Claude Code settings."""
    settings_path = args.settings or Path.home() / ".claude" / "settings.json"
    settings_path = Path(settings_path)

    if not settings_path.exists():
        print(f"{DIM}No settings file found at {settings_path}{RESET}")
        return

    settings = json.loads(settings_path.read_text())
    hooks = settings.get("hooks", {})

    removed_count = 0
    for event in list(hooks.keys()):
        original = hooks[event]
        filtered = [
            m for m in original
            if not any("claude-diff-review" in str(h.get("command", ""))
                      or "diff_review" in str(h.get("command", ""))
                      for h in m.get("hooks", []))
        ]
        if len(filtered) < len(original):
            removed_count += len(original) - len(filtered)
        if filtered:
            hooks[event] = filtered
        else:
            del hooks[event]

    permissions = settings.get("permissions", {})
    allow = permissions.get("allow", [])
    for tool in ["Edit", "Write", "MultiEdit"]:
        if tool in allow:
            allow.remove(tool)

    settings_path.write_text(json.dumps(settings, indent=2))
    print(f"{GREEN}✓{RESET} Removed {removed_count} hook(s). Restart Claude Code.")


# ──────────────────────────────────────────────────────────────────────
# Argument parser
# ──────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="claude-diff",
        description="Review Claude Code edits with consolidated VS Code diffs.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"""
{BOLD}Examples:{RESET}
  claude-diff install          Set up hooks in Claude Code
  claude-diff status           See what files were changed
  claude-diff diff             Open all diffs in VS Code
  claude-diff diff src/app.py  Open diff for one file
  claude-diff accept           Accept all changes, clean up
  claude-diff log              Show full event log for this session
  claude-diff log -f           Follow log in real time
  claude-diff log -n 50        Show last 50 log lines
  claude-diff config --wizard  Re-run the interactive setup wizard
  claude-diff migrate          Sync all cached versions after an upgrade
  claude-diff pause            Pause diff tracking
  claude-diff resume           Resume diff tracking
        """
    )

    subs = parser.add_subparsers(dest="command")

    # status
    subs.add_parser("status", help="Show tracked edits in current session")

    # accept
    subs.add_parser("accept", help="Accept all changes, clean up shadows")

    # diff
    p_diff = subs.add_parser("diff", help="Open diffs in VS Code")
    p_diff.add_argument("path", nargs="?", help="Specific file (omit for all)")
    p_diff.add_argument("--mode", choices=["vscode", "terminal"], help="Override review mode")

    # config
    p_config = subs.add_parser("config", help="View/edit configuration")
    p_config.add_argument("key", nargs="?", help="Config key")
    p_config.add_argument("value", nargs="?", help="New value")
    p_config.add_argument("--wizard", action="store_true", help="Re-run the interactive setup wizard")

    # log
    p_log = subs.add_parser("log", help="Show session event log")
    p_log.add_argument("--lines", "-n", type=int, default=None,
                       help="Show last N lines (default: all)")
    p_log.add_argument("--follow", "-f", action="store_true",
                       help="Follow log in real time (like tail -f)")

    # pause / resume
    subs.add_parser("pause",  help="Pause diff tracking globally (hooks do nothing)")
    subs.add_parser("resume", help="Resume diff tracking")

    # migrate
    subs.add_parser("migrate", help="Sync hooks/lib from newest cache version to older ones")

    # install
    p_install = subs.add_parser("install", help="Install hooks into Claude Code")
    p_install.add_argument("--settings", help="Path to settings.json")

    # uninstall
    p_uninstall = subs.add_parser("uninstall", help="Remove hooks from Claude Code")
    p_uninstall.add_argument("--settings", help="Path to settings.json")

    args = parser.parse_args()

    commands = {
        "status":    cmd_status,
        "accept":    cmd_accept,
        "diff":      cmd_diff,
        "config":    cmd_config,
        "log":       cmd_log,
        "migrate":   cmd_migrate,
        "pause":     cmd_pause,
        "resume":    cmd_resume,
        "install":   cmd_install,
        "uninstall": cmd_uninstall,
    }

    if args.command in commands:
        commands[args.command](args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
